# Provider API keys and the LLM base URL are configured by an administrator in
# Settings -> API keys. SeaSID stores them encrypted in backend/data/seasid.db
# and intentionally ignores provider credential environment variables.

# Optional: Model name (default: MiniMax-M1)
# MiniMax models: MiniMax-M1, MiniMax-Text-01
# OpenAI models: gpt-4o, gpt-4o-mini
OPENAI_MODEL=MiniMax-M1

# ── MiniMax web-search MCP (optional) ─────────────────────────────────────
# Adds the `web_search` and `web_browse` tools to the SeaSID agent. When
# enabled, the API lazily spawns the MiniMax coding-plan MCP subprocess on
# the first agent call so the LLM can pull live web context into dive
# briefings (e.g. "is there a tropical storm heading for Dauin this week?").
#
# Requires `uvx` on PATH (https://docs.astral.sh/uv/) and an API key with
# Token-Plan credits. The key is resolved in this order:
#   1. Encrypted DB row with provider="mcp_minimax" (Settings → API keys)
#   2. Encrypted DB row with provider="llm" (shared with chat completions)
#   3. This env var (dev fallback)
#
# Set to "off" to disable even if a key is configured.
# SEASID_MCP_MINIMAX_ENABLED=true
# MINIMAX_API_KEY=sk-minimax-your-key-here
# Override where the MCP stages its response files. Default: ./data/mcp-minimax
# Must be writable. Keep it outside the project tree if you also watch
# this directory with another tool (Vite/etc.) to avoid full-reload churn.
# MINIMAX_MCP_BASE_PATH=./data/mcp-minimax

# ── v2.1 optional providers ────────────────────────────────────────────────
# Open-Meteo is the default for weather + marine; no key needed.
# Add Stormglass, AQICN, or WorldTides keys through the Settings UI.

# Optional provider overrides — see backend/app/lib/providers/README.md
# SEASID_PROVIDER_WEATHER=open_meteo          # default
# SEASID_PROVIDER_MARINE=open_meteo           # default; set to "stormglass" to enable
# SEASID_PROVIDER_AIR=off                     # default; set to "aqicn" to enable

# Optional: SMTP for email alerts (returns False if any field missing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# Used by the React frontend in production (Vite injects at build time)
VITE_API_URL=http://localhost:8000
VITE_AUTH_ENABLED=true

# API authentication
# Authentication is enabled by default. When SEASID_AUTH_USERS_JSON and
# SEASID_ADMIN_USERNAME/SEASID_ADMIN_PASSWORD are both unset, the API falls
# back to a set of BUILT-IN DEV DEFAULT credentials (see README -> Default
# credentials) and a placeholder JWT secret. A warning is logged on first use.
# For any non-dev deployment, configure real users and a >=32-char secret:
SEASID_AUTH_ENABLED=true
SEASID_AUTH_SECRET=
SEASID_ACCESS_TOKEN_MINUTES=60
# Set this to true to refuse login when no explicit users are configured
# (overrides the built-in dev defaults; login returns 401/503):
# SEASID_AUTH_REQUIRE_EXPLICIT_USERS=true
SEASID_ADMIN_USERNAME=admin
SEASID_ADMIN_PASSWORD=
# For multiple users, use JSON records with username, password_hash, role,
# and site_keys (viewer, operator, data_steward, or admin).
# Generate password hashes with:
#   python -m scripts.hash_password
# SEASID_AUTH_USERS_JSON=[{"username":"guide","password_hash":"...","role":"operator","site_keys":["dauin_muck"]}]


# ── Encryption-at-rest for provider API keys stored in the DB ──────────
# When unset, the API generates ``backend/data/seasid.key`` on first boot.
# For any non-dev deployment set this to a random value of >= 32 chars.
# SEASID_DB_ENCRYPTION_KEY=

# Require an explicit user list (skip the dev-default bootstrap accounts).
# SEASID_AUTH_REQUIRE_EXPLICIT_USERS=true
